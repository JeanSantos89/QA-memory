#!/bin/sh
# qa-memory neutrality guard.
# Blocks sensitive content (Jira keys / credentials / company terms) from entering a commit.
# .githooks/ is excluded: guard scripts legitimately contain pattern literals.
# (Living-doc enforcement removed with the docs/ model in the markdown pivot.)
set -eu

git diff --cached --diff-filter=ACMR -U0 -- . ':!.githooks/' \
  | sh "$(git rev-parse --show-toplevel)/.githooks/neutrality-scan.sh" || exit 1

exit 0
