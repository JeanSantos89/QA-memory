{
  "mcpServers": {
    "qa-memory": {
      "command": "node",
      "args": [
        "$WORKSPACE/QA-memory/packages/mcp-server/dist/index.js"
      ],
      "env": {
        "QA_MEMORY_DB": "$WORKSPACE/QA-memory/.qa-memory/qa-memory.db",
        "QA_MEMORY_INGESTION_DIR": "$WORKSPACE/QA-memory/packages/ingestion",
        "QA_MEMORY_EMBED_CMD": "$HOME/.local/bin/uv run qa-memory embed",
        "QA_MEMORY_LANG": "en",
        "QA_MEMORY_LLM": "ollama",
        "QA_MEMORY_LLM_MODEL": "qwen2.5:14b"
      }
    }
  }
}
